rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Property images: lectura publica, escritura autenticada
    match /property-images/{agentId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == agentId;
    }

    // Avatars: lectura publica, escritura del propio usuario
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
